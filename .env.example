# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
PORT=8000

# User Authentication
# Format: username:password or username1:password1,username2:password2
# Default: admin:admin123 (if not set)
USERS=admin:your_secure_password

# AWS S3 Configuration
# Note: In production, EC2 instances use IAM roles (no credentials needed!)
# These credentials are ONLY for local development/testing
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-2
S3_BUCKET=badart-listing-tool

# CloudFront & Rate Limiting (optional - see docs/CLOUDFRONT_RATE_LIMITING.md)
# CLOUDFRONT_DOMAIN=your-distribution-id.cloudfront.net
# APP_SECRET_TOKEN=your-generated-secure-token-here

# eBay API Configuration
# eBay Environment: 'production' or 'sandbox' (default: sandbox for safety)
# Use sandbox for testing with eBay Sandbox API
EBAY_ENVIRONMENT=sandbox

# Production Credentials (from https://developer.ebay.com/my/keys - Production Keys)
EBAY_PRODUCTION_APP_ID=your-production-app-id-here
EBAY_PRODUCTION_CERT_ID=your-production-cert-id-here
EBAY_PRODUCTION_DEV_ID=your-production-dev-id-here
EBAY_PRODUCTION_TOKEN=your-production-user-token-here

# Sandbox Credentials (from https://developer.ebay.com/my/keys - Sandbox Keys)
EBAY_SANDBOX_APP_ID=your-sandbox-app-id-here
EBAY_SANDBOX_CERT_ID=your-sandbox-cert-id-here
EBAY_SANDBOX_DEV_ID=your-sandbox-dev-id-here
EBAY_SANDBOX_TOKEN=your-sandbox-user-token-here

# eBay Verification Token for Marketplace Account Deletion endpoint
# Required: 32-80 characters
# Generate using: ./deployment/scripts/generate-ebay-token.sh
# This token persists across deployments
EBAY_VERIFICATION_TOKEN=your-64-character-token-here