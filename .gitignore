# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg

# ============================================================================
# Virtual Environment
# ============================================================================
# Local development (in project directory)
venv/
.venv/
env/
ENV/
# Note: In production, venv is at ~/.venv (in user's home directory, outside project)

# ============================================================================
# Environment Variables & Secrets (NEVER COMMIT!)
# ============================================================================
.env
.env.local
.env.*.local
.flaskenv

# ============================================================================
# Flask Instance Data (user-specific, generated at runtime)
# ============================================================================
instance/*
!instance/README.md
!instance/app_defaults.json

# Keep these for deployment:
!instance/app_version

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db

# ============================================================================
# Ansible Vault (NEVER COMMIT PASSWORDS!)
# ============================================================================
.vault_pass
.vault_password
**/vault_pass
**/vault_password

# ============================================================================
# Deployment - Local Configuration Override Files
# ============================================================================
# These files contain your personal deployment settings and should NEVER be committed
# Use these to override the default configs in all.yml and production.yml

# Local override files (highest priority in Ansible)
deployment/group_vars/*.local.yml
deployment/group_vars/**/*.local.yml

# Unencrypted vault files (if you're working with unencrypted secrets locally)
deployment/group_vars/**/vault.yml
!deployment/group_vars/**/vault.yml.example

# Deployment state/summary files
deployment/.deployment-config
deployment/aws-setup-summary.txt
deployment/deployment-summary.txt
**/.secret-rotation-info

# ============================================================================
# Label Tools (Generated Files)
# ============================================================================
label_tools/*.csv
label_tools/*.pdf
!label_tools/README.md
