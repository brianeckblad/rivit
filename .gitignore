# Python
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# Environment variables & secrets
.env
.flaskenv

# GitHub - only track copilot instructions
.github/*
!.github/copilot-instructions.md

# Flask instance data (user-specific, generated at runtime)
instance/*
!instance/README.md
!instance/app_defaults.json
!instance/app_version

# IDE
.idea/

# Logs
*.log

# OS
.DS_Store

# AI agent local working memory (session notes across Copilot conversations)
.copilot/

# Ansible vault passwords (safety net - file lives outside repo at ~/.vault_pass)
**/vault_pass
**/vault_password

# Deployment user config
# all.yml is an empty stub (all config is in encrypted vault.yml)
deployment/group_vars/all.yml
# vault.yml is encrypted and safe to commit — do NOT commit it unencrypted



