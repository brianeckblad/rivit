# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg

# ============================================================================
# Virtual Environment
# ============================================================================
# Local development (in project directory)
venv/
.venv/
env/
ENV/
# Note: In production, venv is at ~/.venv (in user's home directory, outside project)

# ============================================================================
# Environment Variables & Secrets (NEVER COMMIT!)
# ============================================================================
.env
.env.local
.env.*.local
.flaskenv

# ============================================================================
# Flask Instance Data (user-specific, generated at runtime)
# ============================================================================
instance/*
!instance/README.md
!instance/app_defaults.json

# Keep these for deployment:
!instance/app_version

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db

# ============================================================================
# Ansible Vault (NEVER COMMIT PASSWORDS!)
# ============================================================================
.vault_pass
.vault_password
**/vault_pass
**/vault_password

# ============================================================================
# Deployment - User Configuration Files (NEVER COMMIT!)
# ============================================================================
# Users copy .example files to create their actual config files
# Example: cp all.yml.example all.yml
#
# .example files = Templates (IN GIT, get updates)
# Real files     = User configs (IGNORED BY GIT, stay private)

# User's actual configuration files (copied from .example files)
deployment/group_vars/all.yml
deployment/group_vars/vault.yml

# Keep .example template files (these ARE tracked in Git)
!deployment/group_vars/**/*.example

# Deployment state/summary files
deployment/.deployment-config
deployment/aws-setup-summary.txt
deployment/deployment-summary.txt
**/.secret-rotation-info

# ============================================================================
# Label Tools (Generated Files)
# ============================================================================
label_tools/*.csv
label_tools/*.pdf
!label_tools/README.md
