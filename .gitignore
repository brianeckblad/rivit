# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg

# ============================================================================
# Virtual Environment
# ============================================================================
venv/
.venv/
env/
ENV/

# ============================================================================
# Environment Variables & Secrets (NEVER COMMIT!)
# ============================================================================
.env
.env.local
.env.*.local
.flaskenv

# ============================================================================
# Flask Instance Data (user-specific, generated at runtime)
# ============================================================================
instance/*
!instance/README.md
!instance/app_defaults.json

# Keep these for deployment:
!instance/app_version

# ============================================================================
# IDE & Editor
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# OS Files
# ============================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db

# ============================================================================
# Ansible Vault (NEVER COMMIT PASSWORDS!)
# ============================================================================
.vault_pass
.vault_password
**/vault_pass
**/vault_password

# ============================================================================
# Deployment
# ============================================================================
deployment/.deployment-config
deployment/aws-setup-summary.txt
deployment/deployment-summary.txt
**/.secret-rotation-info

# ============================================================================
# Label Tools (Generated Files)
# ============================================================================
label_tools/*.csv
label_tools/*.pdf
!label_tools/README.md
