# ============================================================================
# Server Inventory (EXAMPLE / TEMPLATE)
# ============================================================================
# Copy this file to hosts.yml:
#   cp hosts.yml.example hosts.yml
#
# hosts.yml is gitignored — it contains your real server IP.
# This .example file is the git-tracked template.
#
# Set ansible_host to the value of server_host from vault.yml.
# Run  source scripts/load-vars.sh  to auto-populate from AWS.
#
# Playbook targeting:
#   hosts: localhost    → AWS API calls (provision-app.yml and sub-playbooks)
#   hosts: all          → Remote server (setup.yml, update.yml)
#   hosts: app_servers  → Remote server (harden-permissions.yml)
#   hosts: production   → Remote server (setup-ssl.yml, setup-monitoring.yml)

all:
  children:
    app_servers:
      children:
        production:
          hosts:
            server:
              ansible_host: "{{ server_host }}"
              ansible_connection: ssh
              ansible_user: "{{admin_user}}"
              ansible_ssh_private_key_file: "{{ ssh_key_file }}"

  vars:
    ansible_user: "{{admin_user}}"
    ansible_python_interpreter: /usr/bin/python3

