#!/bin/bash
# ============================================================================
# LOG MONITORING AND ALERTING SCRIPT
# ============================================================================
# Template: deployment/templates/log-monitor.sh.j2
# Purpose:
#   - Monitors application logs for errors and exceptions
#   - Detects when service crashes or becomes unhealthy
#   - Sends SNS notifications for critical issues
#   - Can be run manually or as a cron job
#
# Generated by: setup-monitoring.yml playbook
# Location on server: /opt/{{ app_name }}/bin/log-monitor.sh
#
# How it works:
#   1. Counts errors/exceptions in last 5 minutes
#   2. If count > threshold: Sends SNS alert
#   3. Skips restart checks during active deployment maintenance windows
#   4. Detects whether the app is managed by Supervisor or systemd
#   5. Re-checks after a short grace period before attempting restart
#   6. Cleans old monitor logs (keeps last 30 days)
#
# Configuration:
#   - ERROR_THRESHOLD: How many errors before alerting (default: 10)
#   - sns_topic_arn: Where to send alerts (optional, from vault.yml)
#   - Log location: /var/log/{{ app_name }}/
#
# Usage:
#   # Run manually to check health
#   /opt/{{ app_name }}/bin/log-monitor.sh
#
#   # Add to cron for periodic monitoring (every 5 minutes)
#   */5 * * * * /opt/{{ app_name }}/bin/log-monitor.sh
#
#   # Check monitoring logs
#   tail -f /var/log/{{ app_name }}/monitor.log
#
# Alerts include:
#   - Subject: "{{ app_display_name }}: High Error Rate"
#   - Subject: "{{ app_display_name }}: Service Restarted"
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
# ============================================================================

LOG_DIR="/var/log/{{ app_name }}"
ERROR_THRESHOLD=10
MAINTENANCE_LOCK="/run/{{ app_name }}-monitor.maintenance"
MAINTENANCE_WINDOW_SECONDS=900
RECHECK_DELAY_SECONDS=20
SUPERVISOR_PROGRAM="{{ service_name }}"
SUPERVISOR_CONF="/etc/supervisor/conf.d/{{ service_name }}.conf"
SYSTEMD_UNITS="{{ service_name }}.service {{ app_name }}.service {{ service_name }} {{ app_name }}"

log_message() {
    echo "$(date): $1" >> "$LOG_DIR/monitor.log"
}

send_sns_alert() {
    local subject="$1"
    local message="$2"

    {% if sns_topic_arn is defined and sns_topic_arn %}
    aws sns publish \
        --topic-arn "{{ sns_topic_arn }}" \
        --subject "$subject" \
        --message "$message" \
        --region "{{ aws_region }}"
    {% else %}
    return 0
    {% endif %}
}

maintenance_lock_is_active() {
    local lock_mtime
    local now
    local age

    [ -f "$MAINTENANCE_LOCK" ] || return 1

    lock_mtime=$(stat -c %Y "$MAINTENANCE_LOCK" 2>/dev/null || echo 0)
    [ "$lock_mtime" -gt 0 ] || return 1

    now=$(date +%s)
    age=$((now - lock_mtime))
    [ "$age" -lt "$MAINTENANCE_WINDOW_SECONDS" ]
}

get_supervisor_status() {
    supervisorctl status "$SUPERVISOR_PROGRAM" 2>/dev/null || true
}

has_supervisor_program() {
    local status_output

    [ -f "$SUPERVISOR_CONF" ] || return 1
    command -v supervisorctl >/dev/null 2>&1 || return 1

    status_output=$(get_supervisor_status)
    printf '%s\n' "$status_output" | grep -q "^$SUPERVISOR_PROGRAM[[:space:]]"
}

get_systemd_unit_name() {
    local unit

    command -v systemctl >/dev/null 2>&1 || return 1

    for unit in $SYSTEMD_UNITS; do
        if systemctl cat "$unit" >/dev/null 2>&1; then
            printf '%s\n' "$unit"
            return 0
        fi
    done

    return 1
}

detect_service_manager() {
    local status_output
    local unit_name

    if has_supervisor_program; then
        status_output=$(get_supervisor_status)
        if printf '%s\n' "$status_output" | grep -q "RUNNING"; then
            printf 'supervisor\n'
            return 0
        fi
    fi

    unit_name=$(get_systemd_unit_name || true)
    if [ -n "$unit_name" ] && systemctl is-active --quiet "$unit_name"; then
        printf 'systemd:%s\n' "$unit_name"
        return 0
    fi

    if has_supervisor_program; then
        printf 'supervisor\n'
        return 0
    fi

    if [ -n "$unit_name" ]; then
        printf 'systemd:%s\n' "$unit_name"
        return 0
    fi

    return 1
}

is_service_running() {
    local manager="$1"
    local unit_name

    case "$manager" in
        supervisor)
            get_supervisor_status | grep -q "RUNNING"
            ;;
        systemd:*)
            unit_name="${manager#systemd:}"
            systemctl is-active --quiet "$unit_name"
            ;;
        *)
            return 1
            ;;
    esac
}

restart_service() {
    local manager="$1"
    local unit_name

    case "$manager" in
        supervisor)
            supervisorctl restart "$SUPERVISOR_PROGRAM"
            ;;
        systemd:*)
            unit_name="${manager#systemd:}"
            systemctl restart "$unit_name"
            ;;
        *)
            return 1
            ;;
    esac
}

# Check for errors in the last 5 minutes
ERROR_COUNT=$(find "$LOG_DIR" -name "*.log" -type f -mmin -5 -exec grep -i "error\|exception\|critical" {} \; | wc -l)

if [ "$ERROR_COUNT" -gt "$ERROR_THRESHOLD" ]; then
    log_message "High error count detected: $ERROR_COUNT errors in last 5 minutes"
    send_sns_alert "{{ app_display_name }}: High Error Rate" "Detected $ERROR_COUNT errors in the last 5 minutes"
fi

# Skip auto-restarts during intentional deployment / maintenance windows.
if maintenance_lock_is_active; then
    log_message "Skipping service check because deployment maintenance lock is active."
    exit 0
fi

SERVICE_MANAGER=$(detect_service_manager || true)

if [ -z "$SERVICE_MANAGER" ]; then
    log_message "No supported service manager found for {{ service_name }}. Skipping service check."
    exit 0
fi

if ! is_service_running "$SERVICE_MANAGER"; then
    sleep "$RECHECK_DELAY_SECONDS"

    if maintenance_lock_is_active; then
        log_message "Skipping restart because deployment maintenance lock became active during grace period."
        exit 0
    fi

    if is_service_running "$SERVICE_MANAGER"; then
        log_message "Service {{ service_name }} recovered during ${RECHECK_DELAY_SECONDS}s grace period."
        exit 0
    fi

    log_message "Service {{ service_name }} is not running under ${SERVICE_MANAGER%%:*}! Attempting restart..."

    if restart_service "$SERVICE_MANAGER"; then
        sleep 5

        if is_service_running "$SERVICE_MANAGER"; then
            log_message "Service {{ service_name }} restarted successfully."
            send_sns_alert "{{ app_display_name }}: Service Restarted" "Service was down and has been automatically restarted"
        else
            log_message "Restart command completed, but service {{ service_name }} is still not running."
            send_sns_alert "{{ app_display_name }}: Service Restart Failed" "Automatic restart was attempted but the service is still down"
        fi
    else
        log_message "Failed to restart service {{ service_name }} via ${SERVICE_MANAGER%%:*}."
        send_sns_alert "{{ app_display_name }}: Service Restart Failed" "Automatic restart failed while attempting to recover the service"
    fi
fi

# Clean old monitor logs (keep last 30 days)
find "$LOG_DIR" -name "monitor.log" -type f -mtime +30 -delete

