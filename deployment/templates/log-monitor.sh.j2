#!/bin/bash
# Log monitoring script for {{ app_name }}
# Generated by Ansible

LOG_DIR="/var/log/{{ app_name }}"
ERROR_THRESHOLD=10

# Check for errors in the last 5 minutes
ERROR_COUNT=$(find "$LOG_DIR" -name "*.log" -type f -mmin -5 -exec grep -i "error\|exception\|critical" {} \; | wc -l)

if [ "$ERROR_COUNT" -gt "$ERROR_THRESHOLD" ]; then
    echo "$(date): High error count detected: $ERROR_COUNT errors in last 5 minutes" >> "$LOG_DIR/monitor.log"

    # Send SNS notification if configured
    {% if sns_topic_arn is defined and sns_topic_arn %}
    aws sns publish \
        --topic-arn "{{ sns_topic_arn }}" \
        --subject "{{ app_display_name }}: High Error Rate" \
        --message "Detected $ERROR_COUNT errors in the last 5 minutes" \
        --region "{{ aws_region }}"
    {% endif %}
fi

# Check if service is running
if ! systemctl is-active --quiet {{ app_name }}; then
    echo "$(date): Service {{ app_name }} is not running! Attempting restart..." >> "$LOG_DIR/monitor.log"
    systemctl restart {{ app_name }}

    {% if sns_topic_arn is defined and sns_topic_arn %}
    aws sns publish \
        --topic-arn "{{ sns_topic_arn }}" \
        --subject "{{ app_display_name }}: Service Restarted" \
        --message "Service was down and has been automatically restarted" \
        --region "{{ aws_region }}"
    {% endif %}
fi

# Clean old monitor logs (keep last 30 days)
find "$LOG_DIR" -name "monitor.log" -type f -mtime +30 -delete

