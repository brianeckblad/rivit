# ============================================================================
# AUTOMATIC APT UPDATES CONFIGURATION
# ============================================================================
# Template: deployment/templates/20auto-upgrades.j2
# Purpose:
#   - Enables automatic daily apt package updates
#   - Works with 50unattended-upgrades.j2 (which decides WHAT to update)
#   - This file enables the WHEN (runs apt update daily)
#
# Generated by: setup-security-hardening.yml playbook
# Location on server: /etc/apt/apt.conf.d/20auto-upgrades
#
# Configuration:
#   - Update-Package-Lists: Run apt update daily (check for new versions)
#   - Download-Upgradeable-Packages: Download security patches
#   - AutocleanInterval: Clean apt cache every 7 days
#   - Unattended-Upgrade: Run the unattended-upgrades tool daily
#
# How updates work (chronologically):
#   1. 20auto-upgrades.j2 (THIS FILE) enables the process
#   2. APT runs daily via cron/systemd timer
#   3. 50unattended-upgrades.j2 controls which packages are upgraded
#   4. Security patches auto-installed, infrastructure patches skipped
#
# Monitoring:
#   /var/log/apt/history.log          # What was installed
#   /var/log/unattended-upgrades/     # Detailed logs
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
# ============================================================================

APT::Periodic::Update-Package-Lists "1";
APT::Periodic::Download-Upgradeable-Packages "1";
APT::Periodic::AutocleanInterval "7";
APT::Periodic::Unattended-Upgrade "1";
