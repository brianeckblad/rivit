# ============================================================================
# RSYSLOG LOG ROTATION CONFIGURATION
# ============================================================================
# Template: deployment/templates/rsyslog-rotation.j2
# Purpose:
#   - Rotates system logs (syslog, auth, kernel, mail, etc.)
#   - Prevents system logs from consuming all disk space
#   - Configures retention and compression
#
# Generated by: setup.yml playbook
# Location on server: /etc/logrotate.d/rsyslog
#
# System logs included:
#   - /var/log/syslog        # General system messages
#   - /var/log/auth.log      # SSH, sudo, login attempts
#   - /var/log/kernel.log    # Kernel messages
#   - /var/log/mail.*        # Mail server logs
#   - /var/log/daemon.log    # System daemons
#
# Rotation policy:
#   - Frequency: Daily
#   - Retention: 7 rotated files (1 week of logs)
#   - Compression: gzip (saves ~90% disk space)
#   - File naming: syslog.1, syslog.2.gz, etc.
#
# Why important:
#   - Auth logs: Track login attempts, SSH access, sudo usage
#   - System logs: Diagnose kernel issues, driver problems
#   - Mail logs: Troubleshoot email delivery
#
# Disk space example:
#   Without rotation: syslog could grow to 10GB+ over months
#   With rotation: Keeps ~50MB of logs (7 files * ~7MB each)
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
# ============================================================================

/var/log/syslog
/var/log/mail.info
/var/log/mail.warn
/var/log/mail.err
/var/log/mail.log
/var/log/daemon.log
/var/log/kern.log
/var/log/auth.log
/var/log/user.log
/var/log/lpr.log
/var/log/cron.log
/var/log/debug
/var/log/messages
{
    rotate 7
    daily
    missingok
    notifempty
    delaycompress
    compress
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}
