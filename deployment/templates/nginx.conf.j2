# ============================================================================
# NGINX REVERSE PROXY CONFIGURATION
# ============================================================================
# Template: deployment/templates/nginx.conf.j2
# Purpose:
#   - Reverse proxy between public internet and gunicorn app (localhost:8000)
#   - TLS/SSL termination (If domain configured)
#   - Rate limiting and DDoS protection
#   - Security headers and WAF-like filtering
#   - Static file serving with caching
#
# Generated by: setup-nginx.yml playbook during deployment
# Location on server: /etc/nginx/sites-available/{{ app_name }}
#
# Key Features:
#   ✓ Automatic SSL detection (if certificate exists)
#   ✓ HTTP→HTTPS redirect (when SSL enabled)
#   ✓ Rate limiting zones (login, API, general)
#   ✓ Security headers (CSP, HSTS, X-Frame-Options, etc.)
#   ✓ Path-based WAF filtering (blocks common attacks)
#   ✓ Static asset serving with cache headers
#   ✓ Large file upload support (5GB limit)
#   ✓ Fail2ban integration (429 responses trigger bans)
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
#     Edit group_vars/vault.yml and rerun setup-nginx.yml instead
#
# Variables from vault.yml:
#   - server_name: Domain (e.g., myapp.com) or "_" for IP-only
#   - service_name: Used in log filenames
#   - app_dir: Application directory
# ============================================================================

{% set ssl_cert_path = '/etc/letsencrypt/live/' + server_name + '/fullchain.pem' %}
{# has_ssl is passed in by the playbook via a remote stat check.
   Ansible passes it as a string, so compare explicitly. #}
{% set has_ssl = has_ssl | default(false) | bool %}

# ============================================================================
# RATE LIMITING ZONES — namespaced per app to support multiple apps on one host
# ============================================================================
# Zone names are prefixed with the app_name so two apps on the same server
# do not collide (nginx requires globally unique zone names).
# Zones are per-IP address and reset after the time window expires.
# ============================================================================
limit_req_zone $binary_remote_addr zone={{ app_name }}_login_limit:10m rate=20r/m;
limit_req_zone $binary_remote_addr zone={{ app_name }}_api_limit:10m rate=200r/m;
limit_req_zone $binary_remote_addr zone={{ app_name }}_general_limit:10m rate=300r/m;

{% if has_ssl %}
# HTTPS - main application server
server {
    listen 443 ssl http2;
    server_name {{ server_name | default('_') }};

    # SSL certificates
    ssl_certificate /etc/letsencrypt/live/{{ server_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_name }}/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;

    # SSL stapling (using fullchain.pem which contains the full certificate chain)
    # Note: If the certificate doesn't have an OCSP responder URL, this will be ignored
    ssl_trusted_certificate /etc/letsencrypt/live/{{ server_name }}/fullchain.pem;
    ssl_stapling on;
    ssl_stapling_verify on;

    # HSTS (1 year, includes subdomains for better security if applicable)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
{% else %}
# HTTP - temporary bootstrap server (certbot needs HTTP to validate domain)
# After setup.yml completes, the SSL branch above is used instead.
# If you see this block active in production, SSL setup may have failed.
# Re-run: ansible-playbook playbooks/setup-ssl.yml --vault-password-file ~/.vault_pass
server {
    listen 80;
    server_name {{ server_name | default('_') }};
{% endif %}

    # Hide nginx version
    server_tokens off;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "geolocation=(), microphone=(), camera=()" always;

    # Content Security Policy (adjust as needed for your app)
    # Allow S3 images and eBay images via connect-src for fetch() API
    # style-src-elem allows external stylesheets, manifest-src allows site.webmanifest
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.amazonaws.com https://*.ebayimg.com; manifest-src 'self';" always;

    # Increase client body size for large file uploads (5000MB for ZIP files)
    client_max_body_size 5000M;

    # Timeout settings for large uploads
    client_body_timeout 300s;
    proxy_read_timeout 300s;

    # Access and error logs
    access_log /var/log/nginx/{{ service_name }}_access.log;
    error_log /var/log/nginx/{{ service_name }}_error.log;

    # Custom error pages
    error_page 404 /404.html;
    error_page 500 /500.html;
    error_page 502 /502.html;
    error_page 503 /503.html;

    location ~ ^/(404|500|502|503)\.html$ {
        root {{ app_dir }}/app/static;
        internal;
    }

    # Deny access to hidden files
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Deny access to backup files
    location ~ ~$ {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Allow Let's Encrypt certificate renewals (must be before denials)
    location ^~ /.well-known/acme-challenge/ {
        allow all;
        root /var/www/html;
    }

    # Static files - highest priority to prevent blocking by other rules
    # This must be processed before the WAF rules below
    location ^~ /static/ {
        alias {{ app_dir }}/app/static/;
        expires 30d;
        add_header Cache-Control "public, immutable";
        access_log off;

        # Explicitly allow common static file types
        location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|webmanifest|json)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }

    # Block access to sensitive application directories
    location ~ ^/(instance|deployment|docs|tests|\.git|\.github|\.vscode|__pycache__|\.pytest_cache) {
        deny all;
        access_log off;
        log_not_found off;
        return 444;
    }

    # Block access to sensitive files
    location ~ \.(py|pyc|pyo|log|md|txt|csv|json|yml|yaml|toml|ini|conf)$ {
        deny all;
        access_log off;
        log_not_found off;
        return 444;
    }

    # Analytics dashboard (require authentication at Flask level)
    # IMPORTANT: This must be BEFORE the WAF blacklist below that blocks /admin
    location ~ ^/admin/analytics(/.*)?$ {
        # Rate limiting for analytics
        limit_req zone={{ app_name }}_general_limit burst=50 nodelay;
        limit_req_status 429;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # WAF-style path blacklist - block common attack vectors and scanning attempts
    # Note: /admin/analytics is allowed above, this blocks other /admin paths
    location ~ ^/(admin|phpmyadmin|wp-admin|wp-login|wp-content|xmlrpc\.php|config|\.aws|\.env|backup|db|database|sql|shell|cmd|eval|cgi-bin|scripts|console|api\.php|rest\.php) {
        deny all;
        access_log off;
        log_not_found off;
        return 444;  # Close connection without response
    }

    # Block path traversal attacks and environment/proc file access attempts
    location ~ (\.env|\.git|proc/|environ|\.aws|\.ssh|\.bash|\.profile|\.htaccess|\.htpasswd|web\.config) {
        deny all;
        access_log off;
        log_not_found off;
        return 444;
    }

    # Block encoded path traversal attempts (double-encoded, etc.)
    location ~ (%2e|%252e|%2f|%252f|%5c|%255c) {
        deny all;
        access_log off;
        log_not_found off;
        return 444;
    }

    # Block common vulnerability scanner paths
    location ~ ^/(@fs|@vite|__vite|node_modules|vendor|app/|root/) {
        deny all;
        access_log off;
        log_not_found off;
        return 444;
    }

    # Authentication routes (publicly accessible)
    location ~ ^/(login|logout)$ {
        # Rate limiting to prevent brute force
        limit_req zone={{ app_name }}_login_limit burst=30 nodelay;
        limit_req_status 429;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Main application pages (require authentication at Flask level)
    location ~ ^/(add|add-from-image|browse|download(/ebay)?|price-lookup|account|trash|ebay-listings)$ {
        # Rate limiting for authenticated pages
        limit_req zone={{ app_name }}_general_limit burst=100 nodelay;
        limit_req_status 429;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # eBay Marketplace Account Deletion endpoint (public - required by eBay)
    location = /api/ebay/marketplace-account-deletion {
        # Rate limiting for public eBay webhook
        limit_req zone={{ app_name }}_api_limit burst=20 nodelay;
        limit_req_status 429;

        # Only allow eBay's IP ranges (optional - add if eBay provides specific IPs)
        # For now, allowing all as eBay doesn't publish webhook IPs
        allow all;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # API routes (require authentication at Flask level)
    location /api/ {
        # Rate limiting for API
        limit_req zone={{ app_name }}_api_limit burst=50 nodelay;
        limit_req_status 429;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings for eBay API calls (can take longer)
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Root path (home/dashboard)
    location = / {
        # Rate limiting for home page (60 requests per minute)
        limit_req zone={{ app_name }}_general_limit burst=20 nodelay;
        limit_req_status 429;

        proxy_pass http://{{ gunicorn_bind }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Prevent buffer overflow attacks
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        # Timeout settings
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
    }

    # Deny all other paths not explicitly allowed above
    location / {
        deny all;
        access_log off;
        return 444;  # Close connection without response
    }
}

{% if has_ssl %}
# HTTP to HTTPS redirect
server {
    listen 80;
    server_name {{ server_name }};

    # Allow Let's Encrypt certificate renewals
    location ^~ /.well-known/acme-challenge/ {
        allow all;
        root /var/www/html;
    }

    location / {
        if ($host = {{ server_name }}) {
            return 301 https://$host$request_uri;
        }
        return 404;
    }
}
{% endif %}
