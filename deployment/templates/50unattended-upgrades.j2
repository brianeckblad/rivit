# ============================================================================
# UNATTENDED SECURITY UPDATES CONFIGURATION
# ============================================================================
# Template: deployment/templates/50unattended-upgrades.j2
# Purpose:
#   - Automatically applies security updates to system packages
#   - Prevents exploitation of known vulnerabilities
#   - Reduces manual patching overhead
#
# Generated by: setup-security-hardening.yml playbook
# Location on server: /etc/apt/apt.conf.d/50unattended-upgrades
#
# How it works:
#   1. apt runs daily (via /etc/apt/apt.conf.d/20auto-upgrades)
#   2. Checks for security updates
#   3. Downloads and installs automatically
#   4. Optional: Reboots if kernel updated (configurable)
#   5. Logs all activity to /var/log/unattended-upgrades/
#
# Security vs. Stability:
#   - Security patches: Always installed (critical vulnerabilities)
#   - Infrastructure updates: Skipped (could break system)
#   - Kernel updates: Optional auto-reboot (set Automatic-Reboot)
#
# Monitoring updates:
#   tail -f /var/log/unattended-upgrades/unattended-upgrades.log
#   apt-listchanges  # Show what's being updated
#
# Configuration options:
#   - Automatic-Reboot: Auto-reboot if kernel updated
#   - Automatic-Reboot-Time: When to reboot (default 03:00)
#   - Package-Blacklist: Never update these packages
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
# ============================================================================

// Automatically upgrade packages from these origins
Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}";
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
};

// List of packages to not update automatically
Unattended-Upgrade::Package-Blacklist {
};

// Automatically reboot WITHOUT CONFIRMATION if required after update
// Set to false for production if you want manual control
Unattended-Upgrade::Automatic-Reboot "false";

// If automatic reboot is enabled and needed, reboot at this time
Unattended-Upgrade::Automatic-Reboot-Time "03:00";

// Remove unused kernel packages and dependencies
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";

// Send email on errors or updates
// Unattended-Upgrade::Mail "root";
// Unattended-Upgrade::MailReport "on-change";
