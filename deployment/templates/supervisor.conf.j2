# ============================================================================
# SUPERVISOR PROCESS MANAGER CONFIGURATION
# ============================================================================
# Template: deployment/templates/supervisor.conf.j2
# Purpose:
#   - Manages the gunicorn process for this app
#   - Keeps application running if it crashes (autorestart)
#   - Easy per-app start/stop/restart on a shared server
#
# Safe on shared servers: each app gets its own conf.d/{app_name}.conf file.
# Reloading supervisor only restarts this app's process.
#
# Generated by: setup.yml playbook
# Location on server: /etc/supervisor/conf.d/{{ app_name }}.conf
#
# Usage:
#   supervisorctl status {{ service_name }}   # Check status
#   supervisorctl start {{ service_name }}    # Start process
#   supervisorctl stop {{ service_name }}     # Stop process
#   supervisorctl restart {{ service_name }}  # Restart process
#   supervisorctl tail {{ service_name }}     # Follow logs
# ============================================================================

[program:{{ service_name }}]
# ============================================================================
# APPLICATION STARTUP COMMAND
# ============================================================================
# Gunicorn configuration:
#   -w: Number of worker processes
#   -b: Bind address and port (127.0.0.1:8000 = localhost only)
#   --timeout: Kill worker if request takes longer
#   --access-logfile: Track all HTTP requests
#   --error-logfile: Gunicorn process errors (worker crashes, timeouts)
#   --log-level: Verbosity (debug, info, warning, error)
#
#   NOTE: Do NOT use --capture-output. Flask writes its own app.log and error.log
#         via RotatingFileHandler. --capture-output would duplicate INFO into
#         Gunicorn's error.log.
# ============================================================================
# gunicorn_workers and gunicorn_threads from vault.yml.
# On a shared server: 1 worker + 4 threads per app balances memory and concurrency.
command={{ venv_dir }}/bin/gunicorn -w {{ gunicorn_workers | default(1) }} --threads {{ gunicorn_threads | default(4) }} -b {{ gunicorn_bind }} --timeout {{ gunicorn_timeout }} --worker-tmp-dir /tmp --control-socket /tmp/{{ service_name }}-gunicorn.ctl --access-logfile {{ log_dir }}/access.log --error-logfile {{ log_dir }}/error.log --log-level warning "runapp:app"

# Working directory for the process
directory={{ app_dir }}

# Run as unprivileged user (security best practice)
user={{ app_runtime_user }}

# Auto-start when supervisor starts
autostart=true

# Auto-restart if process exits
autorestart=true

# Kill all child processes when stopping
stopasgroup=true
killasgroup=true

# Log file locations
stderr_logfile={{ log_dir }}/app.log
stdout_logfile={{ log_dir }}/app.log

# Environment variables (PATH must include venv, SECRET_NAME/AWS_REGION for Secrets Manager)
environment=PATH="{{ venv_dir }}/bin",SECRET_NAME="{{ secret_name }}",AWS_REGION="{{ aws_region }}",APP_SERVICE_NAME="{{ service_name }}",APP_NAME="{{ app_name }}"
