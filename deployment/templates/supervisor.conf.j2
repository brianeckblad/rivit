[program:{{ service_name }}]
command={{ venv_dir }}/bin/gunicorn -w {{ gunicorn_workers }} -b 127.0.0.1:8000 --timeout {{ gunicorn_timeout }} --access-logfile {{ log_dir }}/access.log --error-logfile {{ log_dir }}/error.log --log-level info --capture-output "app:create_app()"
directory={{ app_dir }}
user={{ app_user }}
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
stderr_logfile={{ log_dir }}/app.log
stdout_logfile={{ log_dir }}/app.log
environment=PATH="{{ venv_dir }}/bin"
