# ============================================================================
# APPLICATION CONFIGURATION - LOCAL DEVELOPMENT ONLY
# ============================================================================
# Template: deployment/templates/env.j2
# Purpose:
#   - Used by local_dev_setup_env.py to generate a .env file for local development
#   - NOT used in production — production gets config from systemd env vars
#     and secrets from AWS Secrets Manager
#
# Production configuration sources:
#   - Systemd Environment= directives: SECRET_NAME, AWS_REGION,
#     APP_SERVICE_NAME, COMIC_IMAGE_PATH, CLOUDWATCH_NAMESPACE
#   - AWS Secrets Manager: all credentials and sensitive config
#
# ⚠️  This template is NOT referenced by any deployment playbook.
#     It exists solely for the local development setup script.
# ============================================================================

# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
# These control the Flask application behavior
# - FLASK_ENV: Controls debug mode and error reporting
# - DEBUG: Enables/disables Flask debug mode (always off in production)
#
# Note: SECRET_KEY is stored in AWS Secrets Manager (not in this file)
# ============================================================================
FLASK_ENV={{ flask_env | default('production') }}
DEBUG={{ flask_debug | default('False') }}

# Server Configuration
# - PORT: Gunicorn listens on this port (internal only, nginx proxies)
# - HOST: Bind address (0.0.0.0 = localhost only when behind nginx)
PORT=8000
HOST=0.0.0.0

# ============================================================================
# AWS SECRETS MANAGER CONFIGURATION
# ============================================================================
# RECOMMENDED APPROACH: Store sensitive data in AWS Secrets Manager
#
# Benefits:
#   - Secrets never stored in files or environment variables
#   - Automatic rotation support
#   - Audit trail of all access
#   - Least privilege via IAM roles
#
# How it works:
#   1. EC2 instance has an IAM role with Secrets Manager read access
#   2. Application's config.py calls get_secrets_from_aws() at startup
#   3. Secrets are fetched and cached in memory
#   4. Fallback to environment variables if Secrets Manager unavailable
#
# SECRET_NAME points to the Secrets Manager secret containing:
#   - SECRET_KEY (Flask session signing)
#   - EBAY_PRODUCTION_APP_ID, EBAY_VERIFICATION_TOKEN, etc.
#   - APP_DEFAULT_USERNAME, APP_DEFAULT_PASSWORD
#   - CLOUDFRONT_DOMAIN, APP_SECRET_TOKEN
#   - SNS_TOPIC_ARN
#
# ⚠️  CRITICAL: Never put secrets in this file
#     All secrets are in AWS Secrets Manager
# ============================================================================
SECRET_NAME={{ secret_name }}
AWS_REGION={{ aws_region }}

# ============================================================================
# S3 CONFIGURATION
# ============================================================================
# S3 bucket stores application data (images, backups, archives)
#
# IAM Role Security:
#   - EC2 instance has an IAM role with S3 access
#   - No AWS credentials needed in this file
#   - Least privilege principle: only access to specific bucket
#
# Variables:
#   - S3_BUCKET_NAME: Bucket created during infrastructure setup
#   - S3_FOLDER: Subdirectory within bucket (e.g., 'data', 'backups')
# ============================================================================
S3_BUCKET_NAME={{ s3_bucket_name }}
S3_FOLDER={{ s3_folder }}

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Core application settings linking to infrastructure
# - COMIC_IMAGE_PATH: Where uploaded comic images are stored
# - APP_SERVICE_NAME: systemd service name (used for logging, restarts)
# - CLOUDWATCH_NAMESPACE: Custom metrics namespace in CloudWatch
# ============================================================================
COMIC_IMAGE_PATH={{ app_dir }}/instance/item_images
APP_SERVICE_NAME={{ service_name }}
CLOUDWATCH_NAMESPACE={{ app_display_name }}


# ============================================================================
# SECRET MANAGEMENT DETAILS
# ============================================================================
# This file intentionally contains NO sensitive secrets for several reasons:
#
# 1. ROTATION: AWS Secrets Manager allows secret rotation without redeployment
# 2. AUDIT: All access to secrets is logged in AWS CloudTrail
# 3. LEAST PRIVILEGE: Only app process can access (via IAM role)
# 4. GITOPS-SAFE: This file can be checked into source control
#
# Application startup sequence (in config.py):
#   1. Load this .env file
#   2. Call get_secrets_from_aws() to fetch from Secrets Manager
#   3. Merge with environment variables
#   4. Use sensible defaults for missing values
#
# To view secrets:
#   aws secretsmanager get-secret-value --secret-id {{ secret_name }} --region {{ aws_region }}
#
# To update secrets:
#   aws secretsmanager update-secret-value --secret-id {{ secret_name }} --region {{ aws_region }} --secret-string '{"key": "value"}'
#
# Troubleshooting:
#   - If app can't access Secrets Manager: Check EC2 IAM role permissions
#   - If secrets not loading: Check 'logs' in CloudWatch Logs
#   - If need to roll back: Use --restore-secret flag in AWS CLI
# ============================================================================

