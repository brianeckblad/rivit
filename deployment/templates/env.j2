# ============================================================================
# APPLICATION CONFIGURATION - AUTO-GENERATED BY DEPLOYMENT
# ============================================================================
# This file is created automatically by setup.yml during deployment.
# You should NOT manually create or edit this file.
#
# Configuration sources:
# - Variables from this template: FLASK_ENV, SECRET_KEY, EBAY_VERIFICATION_TOKEN
# - Secrets from AWS Secrets Manager (via SECRET_NAME below): API keys, passwords, etc.
# - IAM role on EC2: AWS credentials (no credentials in this file!)
# ============================================================================

# Flask Configuration
FLASK_ENV={{ flask_env | default('production') }}
SECRET_KEY={{ secret_key }}
DEBUG={{ flask_debug | default('False') }}

# Server Configuration
PORT=8000
HOST=0.0.0.0

# ============================================================================
# AWS Secrets Manager Configuration
# ============================================================================
# The application uses AWS Secrets Manager to fetch sensitive configuration.
# The EC2 instance has an IAM role that allows secure access to Secrets Manager.
# All secrets (API keys, passwords, etc.) are stored in Secrets Manager,
# NOT in this file.
#
# SECRET_NAME points to the Secrets Manager secret containing:
# - eBay API credentials
# - Application default password
# - SNS topic ARN
# - Any other sensitive configuration
#
# This design keeps secrets out of files and configuration files.
# ============================================================================
SECRET_NAME={{ secret_name }}
AWS_REGION={{ aws_region | default('us-east-1') }}

# ============================================================================
# S3 Configuration
# ============================================================================
# The EC2 instance uses an IAM role to access S3.
# No AWS credentials are needed in this file.
# ============================================================================
S3_BUCKET_NAME={{ s3_bucket_name | default('') }}
S3_FOLDER={{ s3_folder | default('data') }}

# Application Configuration
COMIC_IMAGE_PATH={{ app_dir }}/instance/item_images
APP_SERVICE_NAME={{ service_name }}
CLOUDWATCH_NAMESPACE={{ app_display_name }}

# ============================================================================
# eBay Verification Token (PERSISTED ACROSS DEPLOYMENTS)
# ============================================================================
# This token is required by eBay for Marketplace Account Deletion endpoint.
# It is auto-generated once and then preserved across deployments.
# Do NOT change this value after deployment.
# ============================================================================
EBAY_VERIFICATION_TOKEN={{ ebay_verification_token }}

# ============================================================================
# NOTE: All other secrets are fetched from AWS Secrets Manager
# ============================================================================
# The application's config.py file contains a get_secrets_from_aws() function that:
# 1. Attempts to fetch secrets from AWS Secrets Manager (via SECRET_NAME above)
# 2. Falls back to environment variables if Secrets Manager is unavailable
# 3. Uses hardcoded defaults if nothing is found
#
# This means secrets like API keys, passwords, etc. are NOT in this file.
# They are stored securely in AWS Secrets Manager and accessed via IAM role.
# ============================================================================

