# Flask Configuration
FLASK_ENV={{ flask_env | default('production') }}
SECRET_KEY={{ secret_key }}
DEBUG={{ flask_debug | default('False') }}

# Server Configuration
PORT=8000
HOST=0.0.0.0

# AWS Secrets Manager Configuration
# EC2 instance uses IAM role to access Secrets Manager (no AWS credentials needed!)
SECRET_NAME={{ secret_name }}
AWS_REGION={{ aws_region | default('us-east-1') }}

# S3 Configuration
# EC2 instance uses IAM role to access S3 (no AWS credentials needed!)
S3_BUCKET_NAME={{ s3_bucket_name | default('') }}
S3_FOLDER={{ s3_folder | default('production') }}

# Application Configuration
COMIC_IMAGE_PATH={{ app_dir }}/instance/item_images

# eBay Verification Token (persisted across deployments)
# Required for eBay Marketplace Account Deletion endpoint (32-80 chars)
# This is auto-generated once and persists in .env
EBAY_VERIFICATION_TOKEN={{ ebay_verification_token }}

# Note: All other secrets (eBay API credentials, admin passwords, etc.) are fetched
# from AWS Secrets Manager at runtime using the SECRET_NAME above.
# The IAM role attached to the EC2 instance provides access to Secrets Manager.
