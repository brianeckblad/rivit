# ============================================================================
# FAIL2BAN CONFIGURATION
# ============================================================================
# Template: deployment/templates/jail.local.j2
# Purpose:
#   - Intrusion detection and prevention
#   - Automatically bans IPs after failed login/attack attempts
#   - Protects nginx endpoints against brute force, scanning, and DDoS
#
# Generated by: setup-server-shared.yml / security-hardening.yml playbooks
# Location on server: /etc/fail2ban/jail.local
#
# How it works:
#   1. Monitors log files for attack patterns
#   2. Counts failed attempts per IP
#   3. When threshold reached: Adds IP to firewall blacklist (iptables)
#   4. IP remains banned for ban duration
#   5. Automatically unbans after time expires
#
# Key benefits:
#   ✓ Prevents brute force attacks (auto-ban after N failures)
#   ✓ Protects nginx endpoints (excessive 404s, 403s, rate-limit hits)
#   ✓ Works with WAF (nginx 429 responses = rate limit hits)
#   ✓ Can send email alerts (optional)
#
# WHY [sshd] IS DISABLED:
#   PasswordAuthentication is off — SSH only accepts key auth.
#   SSH key brute-force is computationally infeasible, so the jail serves no
#   purpose.  Worse, ssh-agent key probing generates "Failed publickey" entries
#   in auth.log EVEN on successful logins (one entry per key tried before the
#   right one is accepted).  With several keys in the agent this trips
#   fail2ban and bans the admin after 2-3 legitimate logins.
#
# WHY banaction = iptables-multiport:
#   The Ubuntu default banaction is iptables-allports, which blocks ALL ports
#   (including 22) when any jail fires.  An nginx jail ban would therefore also
#   lock out SSH.  Using iptables-multiport restricts each jail's ban to only
#   the ports that jail monitors (http,https), leaving port 22 unaffected.
#
# WHY [recidive] IS DISABLED:
#   recidive bans last 7 days and survive fail2ban restarts (stored in
#   iptables).  During active deployments, a stray nginx ban can cascade into
#   a week-long SSH lockout that requires EC2 Instance Connect to clear.
#   The nginx jails already ban for 24 h — that is sufficient deterrence.
#
# Monitoring:
#   fail2ban-client status                    # Overall status
#   iptables -L -n                            # See banned IPs
#   tail -f /var/log/fail2ban.log             # Watch banning in action
#
# Adjust thresholds in group_vars/vault.yml:
#   - admin_ip: Your IP — added to ignoreip so you are never banned
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
# ============================================================================

[DEFAULT]
# Ban for 24 hours after 3 failures in a 20-minute window
bantime = 86400
findtime = 1200
maxretry = 3

# Use port-specific bans — prevents nginx jail bans from blocking port 22.
# (Ubuntu default is iptables-allports which would lock out SSH.)
banaction = iptables-multiport

# Admin IP is never banned — always preserved across hardening runs
# admin_ip is set in group_vars/vault.yml (see SECURITY section)
ignoreip = 127.0.0.1/8 ::1{% if admin_ip | default('') != '' %} {{ admin_ip }}/32{% endif %}

# Email notifications (optional - commented out)
# destemail = your-email@example.com
# sendername = Fail2Ban
# action = %(action_mwl)s

[sshd]
# DISABLED: PasswordAuthentication is off — key auth only.
# ssh-agent key probing creates auth.log failures even on successful logins,
# which would cause fail2ban to ban the admin IP after 2-3 logins.
enabled = false

[nginx-http-auth]
enabled = true
port = http,https
logpath = /var/log/nginx/*error.log
maxretry = 3

[nginx-noscript]
enabled = true
port = http,https
logpath = /var/log/nginx/*access.log
maxretry = 3

[nginx-badbots]
enabled = true
port = http,https
logpath = /var/log/nginx/*access.log
maxretry = 1
bantime = 86400

[nginx-botsearch]
enabled = true
port = http,https
logpath = /var/log/nginx/*access.log
maxretry = 1
bantime = 86400

[nginx-limit-req]
enabled = true
port = http,https
logpath = /var/log/nginx/*error.log
maxretry = 2
bantime = 86400

[nginx-404]
enabled = true
port = http,https
logpath = /var/log/nginx/*access.log
maxretry = 20
findtime = 120
bantime = 3600

[nginx-403]
enabled = true
port = http,https
logpath = /var/log/nginx/*access.log
# Higher threshold — legitimate app 403s should not trigger a ban.
# 30 in 60s is a genuine attack pattern, not normal usage.
maxretry = 30
findtime = 60
bantime = 3600

[recidive]
# DISABLED: 7-day bans survive fail2ban restarts (stored in iptables).
# A stray nginx ban can cascade into a week-long SSH lockout that requires
# EC2 Instance Connect to clear. The 24-hour nginx jail bans are sufficient.
enabled = false
