# ============================================================================
# CLOUDWATCH AGENT CONFIGURATION
# ============================================================================
# Template: deployment/templates/cloudwatch-config.json.j2
# Purpose:
#   - Collects application and system logs from EC2 instance
#   - Sends metrics (CPU, Memory, Disk) to CloudWatch
#   - Enables monitoring, alerting, and troubleshooting
#
# Generated by: setup-monitoring.yml playbook
# Location on server: /opt/aws/amazon-cloudwatch-agent/etc/config.json
#
# Key Features:
#   ✓ Logs: Application, nginx, system logs → CloudWatch Logs
#   ✓ Metrics: CPU, Memory, Disk usage → CloudWatch Metrics
#   ✓ Log rotation: Keeps only last 30 days (configurable)
#   ✓ Namespace: Custom namespace for easy filtering
#   ✓ Instance ID: Automatically added to identify which instance
#
# How to use:
#   1. Check logs: aws logs describe-log-groups --region {{ aws_region }}
#   2. View log streams: aws logs describe-log-streams --log-group-name /{{ app_name }}/application
#   3. Query logs: aws logs filter-log-events --log-group-name /{{ app_name }}/application
#
# CloudWatch Insights Queries:
#   # Find errors in last hour:
#   fields @timestamp, @message | filter @message like /ERROR/ | stats count() by bin(5m)
#
#   # Find slow requests (>1 second):
#   fields @duration | filter @duration > 1000 | stats avg(@duration), max(@duration) by bin(1m)
#
# Cost considerations:
#   - Log ingestion: $0.50 per GB
#   - Log storage: $0.03 per GB per month
#   - Metrics: $0.30 per custom metric per month
#   - Queries: $0.005 per query (or use CloudWatch Logs Insights)
#
# ⚠️  DO NOT manually edit - will be overwritten on redeploy
#     Edit group_vars/all.yml and rerun setup-monitoring.yml instead
# ============================================================================
{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  # ========================================================================
  # LOGS COLLECTION
  # ========================================================================
  # Collects application and system logs
  # Each log file streams to CloudWatch Logs with retention policy
  # ========================================================================
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            # Application logs
            "file_path": "/var/log/{{ app_name }}/app.log",
            "log_group_name": "/{{ app_name }}/application",
            "log_stream_name": "{instance_id}/app",
            "retention_in_days": {{ log_retention_days | default(30) }}
          },
          {
            # Application errors
            "file_path": "/var/log/{{ app_name }}/error.log",
            "log_group_name": "/{{ app_name }}/error",
            "log_stream_name": "{instance_id}/error",
            "retention_in_days": {{ log_retention_days | default(30) }}
          },
          {
            # Nginx access log (all HTTP requests)
            "file_path": "/var/log/nginx/{{ app_name }}_access.log",
            "log_group_name": "/{{ app_name }}/nginx-access",
            "log_stream_name": "{instance_id}/access",
            "retention_in_days": {{ log_retention_days | default(30) }}
          },
          {
            # Nginx errors (server errors, not access errors)
            "file_path": "/var/log/nginx/{{ app_name }}_error.log",
            "log_group_name": "/{{ app_name }}/nginx-error",
            "log_stream_name": "{instance_id}/nginx-error",
            "retention_in_days": {{ log_retention_days | default(30) }}
          }
        ]
      }
    }
  },
  # ========================================================================
  # METRICS COLLECTION
  # ========================================================================
  # Publishes system metrics to CloudWatch
  # Enables auto-scaling based on thresholds
  # ========================================================================
  "metrics": {
    "namespace": "{{ app_display_name }}",
    "metrics_collected": {
      # CPU usage percentage
      "cpu": {
        "measurement": [
          {
            "name": "cpu_usage_idle",
            "rename": "CPU_IDLE",
            "unit": "Percent"
          },
          "cpu_usage_iowait"
        ],
        "metrics_collection_interval": 60,
        "totalcpu": false
      },
      # Disk usage percentage
      "disk": {
        "measurement": [
          {
            "name": "used_percent",
            "rename": "DISK_USED",
            "unit": "Percent"
          }
        ],
        "metrics_collection_interval": 60,
        "resources": [
          "/"
        ]
      },
      # Memory usage percentage
      "mem": {
        "measurement": [
          {
            "name": "mem_used_percent",
            "rename": "MEM_USED",
            "unit": "Percent"
          }
        ],
        "metrics_collection_interval": 60
      }
    }
  }
}

