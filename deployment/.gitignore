# Ansible runtime files
*.retry
.ansible/

# Temporary files
/tmp/
*.tmp
*.log

# Ansible fact cache
/tmp/ansible_facts/
ansible_facts/

# ============================================================================
# User Configuration Files (NEVER COMMIT!)
# ============================================================================
# Standard .example file pattern:
#   - .example files are templates (tracked in Git, receive updates)
#   - Real files are user configs (ignored by Git, stay private)
#   - User workflow: cp all.yml.example all.yml
#
# This is the industry-standard configuration pattern

# User's actual configuration files
group_vars/all.yml
group_vars/production.yml
group_vars/**/vault.yml

# Keep .example template files in Git
!group_vars/**/*.example
!group_vars/**/*.yml.example

# Vault password files (NEVER COMMIT!)
.vault_pass
.vault_password
vault_pass.txt
**/vault_pass
**/vault_password

# Deployment state/summary files
.deployment-config
aws-setup-summary.txt
deployment-summary.txt
.secret-rotation-info

# ============================================================================
# Ansible Runtime Files
# ============================================================================

# Backup files
*.bak
*~

# IDE files
.vscode/
.idea/

# macOS
.DS_Store
