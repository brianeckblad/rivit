---
# ============================================================================
# DEPLOYMENT CONFIGURATION — SINGLE SOURCE OF TRUTH
# ============================================================================
# Setup:
#   1. cp vault.yml.example vault.yml
#   2. Fill in all required values
#   3. ansible-vault encrypt vault.yml --vault-password-file ~/.vault_pass
#
# See deployment/docs/guides/PREREQUISITES.md for a description of every variable.
# ============================================================================
# SHARED SERVER MODEL
# ============================================================================
# This deployment targets a server that is already provisioned and shared.
# Each app manages its own AWS resources (S3, IAM, Secrets Manager) and its
# own app stack (git, venv, supervisor process, nginx vhost, SSL cert).
#
# Multiple apps on one server need UNIQUE values for:
#   app_name       — drives paths, group names, supervisor name, log dirs
#   server_name    — domain this app's nginx vhost listens on
#   gunicorn_port  — unique localhost port (app1=8000, app2=8001, …)
# ============================================================================

# ============================================================================
# APPLICATION IDENTITY (REQUIRED)
# ============================================================================
app_name: "your_app_name"
app_display_name: "My Application"
server_name: "your-domain.example.com"       # Must resolve to server_host IP
ssl_email: "you@example.com"                 # For Let's Encrypt renewal notices
service_name: "{{ app_name }}"               # Supervisor process name

# ============================================================================
# SERVER CONNECTION (REQUIRED)
# ============================================================================
# server_host: SSH host/IP of the shared server. Find in EC2 Console → Instances →
#   your server → Public IPv4 address.
server_host: "YOUR_SERVER_IP"
ssh_key_file: "~/.ssh/your-key.pem"         # SSH private key for ansible_ssh_private_key_file

# ============================================================================
# USERS (REQUIRED)
# ============================================================================
admin_user: "ubuntu"                         # OS user that owns files, runs git
app_user: "your_app_runtime"                 # Unprivileged runtime user (no SSH, no shell)

# ============================================================================
# GIT (REQUIRED)
# ============================================================================
git_branch: "main"
git_repo_url: "https://github.com/USER/REPO.git"
git_token: ""                                # GitHub PAT with repo scope (empty = public repo)
git_repo: "{{ git_repo_url | replace('https://', 'https://' + git_token + '@') if git_token | default('') else git_repo_url }}"

# ============================================================================
# AWS (REQUIRED)
# ============================================================================
aws_region: "us-east-2"
s3_bucket_name: "yourname-appname-2026"      # Globally unique across all AWS accounts
s3_folder: "data"
secret_name: "{{ app_name }}/production"
sns_topic_arn: ""                            # SNS ARN for alerts (leave empty to disable)

# ============================================================================
# IAM — SHARED SERVER ROLE (OPTIONAL)
# ============================================================================
# IAM instance role attached to the shared server. provision-app.yml attaches
# the three app-scoped policies to this role automatically.
# Find it: EC2 Console → Instances → your server → IAM role.
# Leave empty to attach IAM policies manually after running create-iam-policies.yml.
server_iam_role_name: ""                     # e.g., "shared-server-ec2-role"

# ============================================================================
# APPLICATION CREDENTIALS (REQUIRED)
# ============================================================================
app_default_username: "admin"
app_default_password: "change-this-strong-password"   # Min 12 chars, include symbols
users: "admin:change-this-strong-password"            # Format: user1:pass1,user2:pass2

# ============================================================================
# FLASK (REQUIRED)
# ============================================================================
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
secret_key: "replace-with-64-char-random-hex-string"
flask_env: "production"

# ============================================================================
# CLOUDFRONT (OPTIONAL)
# ============================================================================
# Set enable_cloudfront: true and run setup-cloudfront.yml to add a CDN.
# After setup, paste the distribution domain into cloudfront_domain, then sync:
#   ansible-playbook playbooks/secret-sync.yml --vault-password-file ~/.vault_pass
enable_cloudfront: false
cloudfront_price_class: "PriceClass_100"
cloudfront_domain: ""
# Generate: openssl rand -hex 32
app_secret_token: ""

# ============================================================================
# PERFORMANCE
# ============================================================================
# gunicorn_port: MUST be unique per app on a shared server.
# Assign sequentially: 8000, 8001, 8002, …
gunicorn_port: "8000"
gunicorn_bind: "127.0.0.1:{{ gunicorn_port }}"
app_port: "{{ gunicorn_port }}"
flask_port: "{{ gunicorn_port }}"
gunicorn_workers: 4
gunicorn_timeout: 120

# ============================================================================
# LOG RETENTION
# ============================================================================
log_retention_days: 20
log_max_size: "10M"

# ============================================================================
# BACKUPS
# ============================================================================
backup_cleanup_hour: "3"
backup_cleanup_minute: "0"
backup_retention_days: 30
s3_version_retention_days: 30

# ============================================================================
# PATHS (derived from app_name — usually no need to change)
# ============================================================================
app_dir: "/opt/{{ app_name }}"
venv_dir: "{{ app_dir }}/.venv"
log_dir: "/var/log/{{ app_name }}"
instance_dir: "{{ app_dir }}/instance"

# ============================================================================
# eBay API (OPTIONAL — leave all empty if not using eBay)
# ============================================================================
ebay_environment: "production"
ebay_production_dev_id: ""
ebay_production_cert_id: ""
ebay_production_app_id: ""
ebay_production_token: ""
ebay_verification_token: ""

