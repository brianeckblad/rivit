---
# Example vault file for secrets
#
# Setup:
# 1. Create vault password: echo 'your-secure-password' > ~/.vault_pass && chmod 600 ~/.vault_pass
# 2. Copy this file: cp vault.yml.example vault.yml
# 3. Edit with your credentials: nano vault.yml
# 4. Encrypt: ansible-vault encrypt vault.yml --vault-password-file ~/.vault_pass
# 5. Commit encrypted vault.yml to git (SAFE when encrypted)
#
# Or create directly:
#   ansible-vault create vault.yml --vault-password-file ~/.vault_pass
#
# NOTE: Encrypted vault.yml should be committed to git for reusable deployments.

# ============================================================================
# Git Repository (REQUIRED)
# ============================================================================
# Contains your GitHub username/org - keep private
vault_git_repo: "https://github.com/YOUR_USERNAME/YOUR_APP_NAME.git"

# ============================================================================
# AWS Configuration (REQUIRED)
# ============================================================================
# NOTE: AWS credentials (access keys) are NOT stored here!
# The EC2 instance uses an IAM role for authentication (more secure)
vault_aws_region: "us-east-2"
vault_s3_bucket_name: "your-unique-bucket-name"
vault_s3_folder: "data"                          # S3 folder/prefix

# SNS Topic ARN (OPTIONAL - for monitoring/alerts)
# vault_sns_topic_arn: "arn:aws:sns:us-east-2:123456789012:your-topic-name"

# ============================================================================
# Application Credentials (REQUIRED)
# ============================================================================
# These are used for the web application login
vault_app_username: "admin"
vault_app_password: "change-this-to-a-strong-password"
