---
# ============================================================================
# DEPLOYMENT CONFIGURATION — SINGLE SOURCE OF TRUTH
# ============================================================================
# This file contains ALL deployment variables: identity, credentials,
# tuning, infrastructure sizing, and computed paths.
#
# Setup:
#   1. Copy this file:   cp vault.yml.example vault.yml
#   2. Edit your values: nano vault.yml
#   3. Encrypt it:       ansible-vault encrypt vault.yml --vault-password-file ~/.vault_pass
#   4. Verify:           ansible-vault view vault.yml --vault-password-file ~/.vault_pass
#
# After encryption, commit to git (encrypted content only).
#
# Edit later:  ansible-vault edit group_vars/vault.yml --vault-password-file ~/.vault_pass
# View later:  ansible-vault view group_vars/vault.yml --vault-password-file ~/.vault_pass
# ============================================================================

# ============================================================================
# APPLICATION IDENTITY (REQUIRED)
# ============================================================================
app_name: "your_app_name"                        # Technical name (e.g., myapp, comic_tracker)
app_display_name: "My Application"               # Human-readable name for systemd/UI
server_name: "your-domain.example.com"           # REQUIRED: Domain for SSL (e.g., myapp.example.com)
                                                 # Must be a real domain pointed at your server
ssl_email: "your-email@example.com"              # REQUIRED: Email for Let's Encrypt SSL notifications
service_name: "{{ app_name }}"                   # systemd service name (usually same as app_name)

# ============================================================================
# USERS (REQUIRED)
# ============================================================================
admin_user: "ubuntu"                             # SSH/deployment user (ubuntu for EC2 Ubuntu AMI)
app_user: "app_runtime"                          # Application runtime user (no SSH, no shell)

# ============================================================================
# GIT (REQUIRED)
# ============================================================================
git_branch: "main"                               # Git branch to deploy
git_repo_url: "https://github.com/YOUR_USERNAME/YOUR_APP.git"
git_token: ""                                    # GitHub PAT (required for private repos, empty for public)
git_repo: "{{ git_repo_url | replace('https://', 'https://' + git_token + '@') if git_token | default('') else git_repo_url }}"

# ============================================================================
# AWS (REQUIRED)
# ============================================================================
aws_region: "us-east-2"                          # AWS region for your resources
aws_root_account_email: "you@example.com"        # AWS root account email (for serial console access)
s3_bucket_name: "your-unique-bucket-name"        # S3 bucket (must be globally unique)
s3_folder: "data"                                # Folder/prefix within S3 bucket
secret_name: "{{ app_name }}/production"            # AWS Secrets Manager secret name
sns_topic_arn: ""                                # SNS topic for alerts (optional)

# ============================================================================
# APPLICATION CREDENTIALS (REQUIRED)
# ============================================================================
app_default_username: "admin"                    # Default web login username
app_default_password: "change-this-password"     # Default web login password
users: "admin:change-this-password"              # Format: user1:pass1,user2:pass2

# ============================================================================
# FLASK (REQUIRED)
# ============================================================================
secret_key: "change-this-to-a-random-secret-key"    # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
flask_port: "8000"
flask_env: "production"

# ============================================================================
# CLOUDFRONT & RATE LIMITING (OPTIONAL)
# ============================================================================
enable_cloudfront: false                         # true = deploy CloudFront CDN
cloudfront_price_class: "PriceClass_100"         # PriceClass_100 | PriceClass_200 | PriceClass_All
cloudfront_domain: ""                            # Filled after CloudFront provisioning
app_secret_token: ""                             # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# ============================================================================
# PERFORMANCE (OPTIONAL)
# ============================================================================
gunicorn_workers: 4                              # Worker processes (2-4 x CPU cores)
gunicorn_timeout: 120                            # Request timeout in seconds
gunicorn_bind: "127.0.0.1:8000"                 # Gunicorn bind address
app_port: "{{ gunicorn_bind.split(':')[1] }}"    # Derived from gunicorn_bind
python_version: "3.10"                           # Python version on target server

# ============================================================================
# LOG RETENTION (OPTIONAL)
# ============================================================================
log_retention_days: 20                           # Days to keep logs before rotation
log_max_size: "10M"                              # Max size per log file

# ============================================================================
# BACKUPS (OPTIONAL)
# ============================================================================
backup_cleanup_hour: "3"                         # Hour to run cleanup (0-23, UTC)
backup_cleanup_minute: "0"                       # Minute to run cleanup (0-59)
backup_retention_days: 30                        # Days to keep backups
s3_version_retention_days: 30                    # Days to keep old S3 versions

# ============================================================================
# STORAGE (EBS VOLUME)
# ============================================================================
# app_dir is the single base path — all other paths derive from it.
app_dir: "/opt/{{ app_name }}"
app_storage_mount_path: "{{ app_dir }}"
ebs_volume_mount_path: "{{ app_dir }}"
venv_dir: "{{ app_dir }}/.venv"
log_dir: "/var/log/{{ app_name }}"
instance_dir: "{{ app_dir }}/instance"

ebs_volume_size: 100                             # EBS volume size in GB
ebs_volume_type: "gp3"                           # gp3 recommended
ebs_volume_encrypted: true
ebs_boot_delete_on_termination: true
ebs_data_delete_on_termination: false
ebs_volume_snapshot_id: ""                       # Set to restore from snapshot
ebs_device_name: "/dev/sdf"
ebs_nvme_device: "/dev/nvme1n1"

# ============================================================================
# EC2
# ============================================================================
ec2_instance_type: "t3.micro"                    # Instance type
assign_public_ip: true
ec2_monitoring_enabled: false
ec2_termination_protection: true
ec2_ebs_optimized: false
ec2_source_dest_check: true

# ============================================================================
# eBay API (OPTIONAL — only if using eBay features)
# ============================================================================
ebay_environment: "production"                   # sandbox or production
ebay_production_dev_id: ""
ebay_production_cert_id: ""
ebay_production_app_id: ""
ebay_production_token: ""
ebay_verification_token: ""


# ============================================================================
# SYSTEM PACKAGES
# ============================================================================
system_packages:
  - python3
  - python3-pip
  - python3-venv
  - python3-dev
  - build-essential
  - nginx
  - git
  - curl
  - supervisor
  - libjpeg-dev
  - zlib1g-dev
  - libpng-dev
  - net-tools
  - xfsprogs
