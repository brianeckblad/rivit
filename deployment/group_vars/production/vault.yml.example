---
# Example vault file for production secrets
#
# Setup:
# 1. Create vault password: echo 'your-secure-password' > ~/.vault_pass && chmod 600 ~/.vault_pass
# 2. Copy this file: cp vault.yml.example vault.yml
# 3. Edit with your credentials: nano vault.yml
# 4. Encrypt: ansible-vault encrypt vault.yml --vault-password-file ~/.vault_pass
# 5. Commit encrypted vault.yml to git (SAFE when encrypted)
#
# Or create directly:
#   ansible-vault create vault.yml --vault-password-file ~/.vault_pass
#
# NOTE: Encrypted vault.yml should be committed to git for reusable deployments.

# Git Repository (contains your GitHub username/org - keep private)
vault_git_repo: "https://github.com/yourusername/app_item_listing_tool.git"

# AWS Credentials
vault_aws_access_key_id: "AKIAXXXXXXXXXXXXXXXX"
vault_aws_secret_access_key: "your-secret-access-key-here"
vault_aws_region: "us-east-2"
vault_s3_bucket_name: "your-bucket-name"
vault_s3_key_prefix: ""  # Optional: prefix for S3 keys (e.g., "prod/")

# Application Credentials
vault_app_username: "your-admin-username"
vault_app_password: "your-secure-password"
